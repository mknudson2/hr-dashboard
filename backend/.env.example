# Email Configuration for HR Dashboard Notifications
# Copy this file to .env and fill in your email credentials

# SMTP Server Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Email Credentials
# For Gmail: Use an App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Sender Email Address
FROM_EMAIL=noreply@nbshr.com

# Enable/Disable Email Notifications (true/false)
# Set to false to disable actual email sending (will print to console instead)
EMAIL_ENABLED=false

# Database Configuration (if different from default)
# DATABASE_URL=sqlite:///./hr_dashboard.db
