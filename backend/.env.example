# ===========================================
# HR DASHBOARD CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your credentials
#
# SECURITY CHECKLIST FOR PRODUCTION:
# [ ] Set ENVIRONMENT=production
# [ ] Generate and set JWT_SECRET_KEY (64+ characters)
# [ ] Generate and set FIELD_ENCRYPTION_KEY (Fernet key)
# [ ] Set ENCRYPTION_SALT (unique per deployment)
# [ ] Configure CORS_ORIGINS with exact production domains
# [ ] Run data encryption migration script
# [ ] Enable HTTPS (handled by reverse proxy/load balancer)

# ===========================================
# ENVIRONMENT (CRITICAL)
# ===========================================
# Set to "production" for production deployments
# Production mode enforces stricter security:
# - Requires encryption keys to be set
# - Enables HSTS headers
# - Restricts error message verbosity
ENVIRONMENT=development

# ===========================================
# SECURITY CONFIGURATION (REQUIRED IN PRODUCTION)
# ===========================================

# JWT Secret Key - MUST be changed in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MINIMUM: 64 characters, cryptographically random
JWT_SECRET_KEY=your-secret-key-generate-a-random-64-char-hex-string

# Field Encryption Key - Used for encrypting sensitive data (SSN, wages, PII)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICAL: Once set, changing this key will make existing encrypted data unreadable!
# REQUIRED in production - application will not start without it
FIELD_ENCRYPTION_KEY=

# Encryption Salt - Used for key derivation if FIELD_ENCRYPTION_KEY is a passphrase
# MUST be unique per deployment, at least 16 characters
# REQUIRED in production when using passphrase-based encryption key
ENCRYPTION_SALT=hr_dashboard_salt_v1

# CORS Origins - Comma-separated list of allowed frontend origins
# In production, set to exact production URLs (no wildcards)
# Example: CORS_ORIGINS=https://hr.yourcompany.com,https://hr-dashboard.yourcompany.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Session Configuration
# SESSION_IDLE_TIMEOUT_MINUTES - User logged out after this many minutes of inactivity
SESSION_IDLE_TIMEOUT_MINUTES=30
# SESSION_MAX_LIFETIME_HOURS - Maximum session duration regardless of activity
SESSION_MAX_LIFETIME_HOURS=8

# ===========================================
# EMAIL PROVIDER SELECTION
# ===========================================
# Choose your email provider: "gmail" or "outlook"
EMAIL_PROVIDER=gmail

# Enable/Disable Email Sending (true/false)
# Set to false for testing (will print to console instead of sending)
EMAIL_ENABLED=false

# ===========================================
# GMAIL CONFIGURATION (for testing/development)
# ===========================================
# IMPORTANT: Use App Password, NOT your regular Gmail password
# Generate App Password at: https://myaccount.google.com/apppasswords
# Prerequisites: 2-Step Verification must be enabled

GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USERNAME=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
GMAIL_FROM_EMAIL=your-email@gmail.com
GMAIL_FROM_NAME=NBS HR Dashboard

# ===========================================
# OUTLOOK/OFFICE365 CONFIGURATION (for production)
# ===========================================
# NOTE: Microsoft deprecated basic auth in Feb 2025
# OAuth 2.0 is REQUIRED - setup Azure AD app first
# Guide: https://learn.microsoft.com/en-us/exchange/client-developer/legacy-protocols/how-to-authenticate-an-imap-pop-smtp-application-by-using-oauth

OUTLOOK_SMTP_SERVER=smtp.office365.com
OUTLOOK_SMTP_PORT=587
OUTLOOK_CLIENT_ID=your-azure-app-client-id
OUTLOOK_TENANT_ID=your-azure-tenant-id
OUTLOOK_CLIENT_SECRET=your-client-secret
OUTLOOK_FROM_EMAIL=hr@yourcompany.com
OUTLOOK_FROM_NAME=HR Department

# ===========================================
# EMAIL SETTINGS
# ===========================================
# Rate limiting (emails per minute)
EMAIL_RATE_LIMIT=50

# Maximum attachment size in MB
EMAIL_ATTACHMENT_MAX_SIZE=25

# Enable email logging to database
EMAIL_LOG_ENABLED=true

# Default reply-to email
EMAIL_REPLY_TO=hr@yourcompany.com

# BCC all emails to this address (for auditing)
EMAIL_BCC=

# Company branding
COMPANY_NAME=NBS
COMPANY_LOGO_URL=https://yourcompany.com/logo.png

# ===========================================
# LEGACY CONFIGURATION (for backward compatibility)
# ===========================================
# These are deprecated but kept for backward compatibility
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@nbshr.com

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# DATABASE_URL=sqlite:///./hr_dashboard.db

# ===========================================
# TEMPLATE CONFIGURATION
# ===========================================
# Path to email templates directory
EMAIL_TEMPLATES_DIR=templates/emails

# Default template language
EMAIL_TEMPLATE_LANGUAGE=en

# ===========================================
# NOTIFICATION PREFERENCES (default settings)
# ===========================================
# These can be overridden per-user in the database

# Onboarding notifications
NOTIFY_NEW_HIRE=true
NOTIFY_FIRST_DAY_REMINDER=true

# Offboarding notifications
NOTIFY_TERMINATION=true
NOTIFY_EXIT_INTERVIEW=true
NOTIFY_ACCESS_REMOVAL=true

# FMLA notifications
NOTIFY_FMLA_APPROVAL=true
NOTIFY_FMLA_REMINDER=true
NOTIFY_FMLA_RETURN=true

# Performance notifications
NOTIFY_REVIEW_REMINDER=true
NOTIFY_REVIEW_COMPLETED=true

# Event notifications
NOTIFY_BIRTHDAY=true
NOTIFY_ANNIVERSARY=true

# Report notifications
NOTIFY_WEEKLY_REPORT=true
NOTIFY_MONTHLY_REPORT=true

# Change notifications
NOTIFY_WAGE_CHANGE=true
NOTIFY_STATUS_CHANGE=true

# ===========================================
# SCHEDULED EMAIL CONFIGURATION
# ===========================================
# Times are in 24-hour format (HH:MM)

# Daily birthday emails
SCHEDULE_BIRTHDAY_TIME=08:00

# Weekly reports (Monday)
SCHEDULE_WEEKLY_REPORT_DAY=monday
SCHEDULE_WEEKLY_REPORT_TIME=09:00

# Monthly reports (1st of month)
SCHEDULE_MONTHLY_REPORT_TIME=09:00

# FMLA return reminders (days before return date)
FMLA_REMINDER_DAYS_BEFORE=7

# Performance review reminders (days before due date)
REVIEW_REMINDER_DAYS_BEFORE=14,7,3,1

# ===========================================
# HR CONTACT CONFIGURATION
# ===========================================
HR_CONTACT_EMAIL=hr-contact@yourcompany.com
HR_CONTACT_NAME=Your Name
HR_SUPPORT_EMAIL=hr@yourcompany.com

# ===========================================
# DEPARTMENT EMAIL RECIPIENTS
# ===========================================
# Comma-separated for multiple recipients
EMAIL_RECIPIENT_401K=401k@yourcompany.com
EMAIL_RECIPIENT_ACCOUNTING=accounting@yourcompany.com
EMAIL_CC_ACCOUNTING=accounting-cc@yourcompany.com
EMAIL_RECIPIENT_COBRA=cobra@yourcompany.com
EMAIL_RECIPIENT_CRM=crm@yourcompany.com
EMAIL_RECIPIENT_DATA_ADMIN=data-admin@yourcompany.com
EMAIL_RECIPIENT_FLEX=flex@yourcompany.com
EMAIL_RECIPIENT_RETIREMENT=retirement@yourcompany.com
EMAIL_RECIPIENT_WELFARE=welfare@yourcompany.com
EMAIL_RECIPIENT_LEADERSHIP=leadership@yourcompany.com

# ===========================================
# TESTING CONFIGURATION
# ===========================================
# Test email recipient (all test emails go here)
TEST_EMAIL_RECIPIENT=test@example.com

# Send test emails on startup
SEND_TEST_EMAIL_ON_STARTUP=false
