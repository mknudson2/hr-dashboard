# =============================================================================
# HR Dashboard - Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in your values
# NEVER commit the actual .env.production file to version control

# -----------------------------------------------------------------------------
# SECURITY KEYS (REQUIRED - Generate unique values!)
# -----------------------------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-a-new-one
FIELD_ENCRYPTION_KEY=your-encryption-key-here-generate-a-new-one

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# SQLite (default - fine for your use case)
DATABASE_URL=sqlite:///./data/hr_dashboard.db

# PostgreSQL (optional - if you want to upgrade later)
# DATABASE_URL=postgresql://user:password@localhost:5432/hr_dashboard

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
# Environment: development, staging, production
ENVIRONMENT=production

# Debug mode (set to false in production)
DEBUG=false

# Your domain (used for CORS and cookie settings)
DOMAIN=bifrostin.com
HR_HUB_URL=https://hr.bifrostin.com
PORTAL_URL=https://portal.bifrostin.com

# CORS Origins (comma-separated if multiple)
CORS_ORIGINS=https://hr.bifrostin.com,https://portal.bifrostin.com

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (Optional - for sending notifications)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@bifrostin.com

# -----------------------------------------------------------------------------
# BACKUP CONFIGURATION (Optional)
# -----------------------------------------------------------------------------
# BACKUP_RETENTION_DAYS=30
# BACKUP_PATH=/var/backups/hr-dashboard
